    "node": ">=20.0.0"
  },
  "dependencies": {
    "@types/react": "^18.0.0"
  },
  "pnpm": {
    "overrides": {
      "yaml": "^2.8.3",
      "flatted": "^3.4.2",
      "minimatch": "^9.0.7",
      "picomatch": "^4.0.4",
      "ajv": "^8.17.1",
      "brace-expansion": "^2.0.3"
